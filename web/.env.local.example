# Copy to .env.local (never commit .env.local) and fill in from your Supabase
# project: URL from Project Settings → Data API; key from Project Settings →
# API Keys → "Publishable key" (sb_publishable_…; the legacy anon key also
# works — NEVER the secret/service_role key). Add the same variables in
# Vercel → Project → Settings → Environment Variables.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_YOUR-KEY

# Web push (optional — needed for /admin ▸ Ειδοποιήσεις). Generate once with:
#   npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Voting (optional): the hash seed mixed into every anonymous voter key —
# SHA-256(seed + device-id + poll-id). Any random string; changing it later
# resets vote deduplication (old voters could vote once more). Defaults to a
# built-in constant when unset.
NEXT_PUBLIC_VOTE_SEED =
