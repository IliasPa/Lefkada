# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# debug logs
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local launcher (runs the web dev server)
start.command

# local changelog
README_Changes.md

# full-resolution logo original (compressed version is committed)
web/public/PegasusFlag.original.png

# Next.js build output / cache — regenerable ("cooked")
.next/
out/
web/.next/
web/out/
next-env.d.ts
*.tsbuildinfo

# local env files
.env*.local

# Supabase CLI local state
supabase/.temp/
